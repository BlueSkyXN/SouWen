# ===== SouWen 配置 =====
# 环境变量优先级最高（高于 souwen.yaml / ~/.config/souwen/config.yaml）
# 完整字段说明见 README.md 与 docs/configuration.md

# ===== 论文数据源 =====
SOUWEN_OPENALEX_EMAIL=your@email.com
SOUWEN_SEMANTIC_SCHOLAR_API_KEY=
SOUWEN_CORE_API_KEY=
SOUWEN_PUBMED_API_KEY=
SOUWEN_UNPAYWALL_EMAIL=your@email.com
SOUWEN_IEEE_API_KEY=
# Zotero（个人/团队文献库）
SOUWEN_ZOTERO_API_KEY=
SOUWEN_ZOTERO_LIBRARY_ID=

# ===== 专利数据源 =====
SOUWEN_USPTO_API_KEY=
SOUWEN_EPO_CONSUMER_KEY=
SOUWEN_EPO_CONSUMER_SECRET=
SOUWEN_CNIPA_CLIENT_ID=
SOUWEN_CNIPA_CLIENT_SECRET=
SOUWEN_LENS_API_TOKEN=
SOUWEN_PATSNAP_API_KEY=

# ===== 网页搜索引擎 — API 类 =====
# 通用爬虫引擎（DuckDuckGo / Yahoo / Brave / Google / Bing / 必应中文 / Startpage / Baidu / Mojeek / Yandex）无需 Key
SOUWEN_TAVILY_API_KEY=
SOUWEN_EXA_API_KEY=
SOUWEN_SERPER_API_KEY=
SOUWEN_BRAVE_API_KEY=
SOUWEN_SERPAPI_API_KEY=
SOUWEN_FIRECRAWL_API_KEY=
SOUWEN_PERPLEXITY_API_KEY=
SOUWEN_LINKUP_API_KEY=
SOUWEN_SCRAPINGDOG_API_KEY=
SOUWEN_METASO_API_KEY=
SOUWEN_ZHIPUAI_API_KEY=             # 智谱 AI Web Search Pro（PR #12）
SOUWEN_ALIYUN_IQS_API_KEY=          # 阿里云 IQS 通义晓搜（PR #13）

# ===== 网页搜索引擎 — 自建实例 =====
SOUWEN_SEARXNG_URL=http://localhost:8888
SOUWEN_WHOOGLE_URL=
SOUWEN_WEBSURFX_URL=

# ===== 社交平台 =====
SOUWEN_TWITTER_BEARER_TOKEN=
SOUWEN_REDDIT_CLIENT_ID=
SOUWEN_REDDIT_CLIENT_SECRET=
SOUWEN_FACEBOOK_APP_ID=
SOUWEN_FACEBOOK_APP_SECRET=

# ===== 开发者 / 视频 / Wiki =====
SOUWEN_GITHUB_TOKEN=
SOUWEN_STACKOVERFLOW_API_KEY=
SOUWEN_YOUTUBE_API_KEY=

# ===== 办公 / 企业 =====
SOUWEN_FEISHU_APP_ID=               # 飞书云文档（PR #7）
SOUWEN_FEISHU_APP_SECRET=

# ===== 网页内容抓取（fetch 提供者）=====
# 零配置：builtin / crawl4ai / newspaper / readability / site_crawler / deepwiki
# 免费：jina_reader（可选 Key 提速）/ wayback / mcp
SOUWEN_JINA_API_KEY=
SOUWEN_SCRAPFLY_API_KEY=
SOUWEN_DIFFBOT_API_TOKEN=
SOUWEN_SCRAPINGBEE_API_KEY=
SOUWEN_ZENROWS_API_KEY=
SOUWEN_SCRAPERAPI_API_KEY=
SOUWEN_APIFY_API_TOKEN=
SOUWEN_CLOUDFLARE_API_TOKEN=
SOUWEN_CLOUDFLARE_ACCOUNT_ID=

# ===== 通用 =====
SOUWEN_PROXY=
# 多代理池（逗号分隔），优先于 SOUWEN_PROXY
SOUWEN_PROXY_POOL=
SOUWEN_TIMEOUT=30
SOUWEN_MAX_RETRIES=3
SOUWEN_DATA_DIR=~/.local/share/souwen
SOUWEN_MAX_CONCURRENCY=10
# auto | curl_cffi | httpx
SOUWEN_DEFAULT_HTTP_BACKEND=auto

# ===== 服务端 =====
# 旧版统一密码（向后兼容；同时作为 visitor / admin 未设置时的回退值）
SOUWEN_API_PASSWORD=
# 双密码模型（v0.6.3+），优先于 SOUWEN_API_PASSWORD
SOUWEN_VISITOR_PASSWORD=
SOUWEN_ADMIN_PASSWORD=
# 未设置任何密码时显式开放管理端点（仅开发 / CI 使用）
SOUWEN_ADMIN_OPEN=
# 受信反向代理（逗号分隔的 IP/CIDR）
SOUWEN_TRUSTED_PROXIES=
# CORS 允许来源（逗号分隔）
SOUWEN_CORS_ORIGINS=
SOUWEN_EXPOSE_DOCS=true

# ===== WARP 代理（Docker 部署专用，可选）=====
SOUWEN_WARP_ENABLED=false
SOUWEN_WARP_MODE=auto
SOUWEN_WARP_SOCKS_PORT=1080
SOUWEN_WARP_ENDPOINT=

# ===== MCP（Model Context Protocol）抓取 =====
# 通过 MCP 调用外部 fetch 工具时使用
# SOUWEN_MCP_SERVER_URL=
# SOUWEN_MCP_TRANSPORT=streamable_http
# SOUWEN_MCP_FETCH_TOOL_NAME=fetch
