{
  "name": "souwen-panel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_SKIN=souwen-classic vite",
    "dev:classic": "VITE_SKIN=souwen-classic vite",
    "dev:carbon": "VITE_SKIN=carbon vite",
    "build": "tsc -b && vite build && cp dist/index.html ../src/souwen/server/panel.html",
    "build:classic": "VITE_SKIN=souwen-classic npm run build",
    "build:carbon": "VITE_SKIN=carbon npm run build",
    "check:artifact": "test -f dist/index.html && test -f ../src/souwen/server/panel.html && cmp -s dist/index.html ../src/souwen/server/panel.html || (echo 'src/souwen/server/panel.html does not match panel/dist/index.html. Run panel build and commit the regenerated artifact.' >&2 && exit 1)",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.0.2",
    "sass-embedded": "^1.86.0",
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.3"
  }
}
