{
  "name": "souwen-panel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:google": "VITE_SKINS=souwen-google vite",
    "dev:nebula": "VITE_SKINS=souwen-nebula vite",
    "dev:carbon": "VITE_SKINS=carbon vite",
    "dev:all": "VITE_SKINS=all vite",
    "build": "tsc -b && vite build",
    "build:local": "npm run build && mkdir -p ../src/souwen/server && cp dist/index.html ../src/souwen/server/panel.html",
    "build:google": "VITE_SKINS=souwen-google npm run build",
    "build:nebula": "VITE_SKINS=souwen-nebula npm run build",
    "build:carbon": "VITE_SKINS=carbon npm run build",
    "build:all": "VITE_SKINS=all npm run build",
    "check:artifact": "test -f dist/index.html || (echo 'panel/dist/index.html missing. Run npm run build first.' >&2 && exit 1)",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.9",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.7",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.0.2",
    "sass-embedded": "^1.86.0",
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.3"
  }
}
